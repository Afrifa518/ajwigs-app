# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Business WhatsApp number (international format, digits only e.g. 233XXXXXXXXX)
# Powers the floating chat button and "Order on WhatsApp" on product pages.
NEXT_PUBLIC_WHATSAPP_NUMBER=

SUPABASE_SERVICE_ROLE_KEY=

# Optional (for later when we re-add Stripe checkout)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Signing secret for the /api/webhooks/stripe endpoint (from the Stripe
# dashboard). The webhook stays inert until this is set.
STRIPE_WEBHOOK_SECRET=
